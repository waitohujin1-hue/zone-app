# Copy to .env and fill in.

# Your Supabase project (Settings > API).
ZONE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
ZONE_SUPABASE_ANON_KEY=your-anon-key

# The Google OAuth client (type "Web application") registered in Supabase's
# Auth > Providers > Google settings. This app needs the SAME client id/secret
# again here because Supabase does not refresh the Google access token for
# you -- once the initial "Googleでログイン" consent is brokered through
# Supabase, this app refreshes the Google Calendar token itself directly
# against Google using these credentials.
ZONE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
ZONE_GOOGLE_CLIENT_SECRET=your-client-secret
